---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Ingeniería Millar — Asesoría técnica para la industria minera',
  description = 'Servicios de asesoría técnica e ingeniería para la industria minera e industrial. Más de 20 años de experiencia. Cobertura nacional.',
} = Astro.props
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <slot />
  </body>
</html>
