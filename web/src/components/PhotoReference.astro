---
// Galería de referencia para el diseñador — eliminar antes del deploy final
// ⚠️ Las URLs originales del cliente (bancoaudiovisual.marcachile.cl) requieren login
// El diseñador debe descargarlas y reemplazar los src en todos los componentes
const photos = [
  { url: 'https://picsum.photos/seed/industria-1/800/450', label: 'General 1' },
  { url: 'https://picsum.photos/seed/industria-2/800/450', label: 'General 2' },
  { url: 'https://picsum.photos/seed/industria-3/800/450', label: 'General 3' },
  { url: 'https://picsum.photos/seed/industria-4/800/450', label: 'General 4' },
  { url: 'https://picsum.photos/seed/industria-5/800/450', label: 'General 5' },
  { url: 'https://picsum.photos/seed/industria-6/800/450', label: 'General 6' },
]
---

<!-- ⚠️ SOLO PARA DISEÑO — eliminar este componente antes del deploy final -->
<section class="py-16 bg-yellow-50 border-y-2 border-yellow-400">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6">
      <span class="bg-yellow-400 text-yellow-900 text-xs font-bold px-2 py-1 rounded">REFERENCIA DISEÑADOR</span>
      <p class="text-yellow-800 text-sm font-medium">
        Fotos entregadas por el cliente — disponibles para usar en cualquier sección.
        Eliminar este bloque antes del deploy.
      </p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {photos.map((photo, i) => (
        <a href={photo.url} target="_blank" rel="noopener noreferrer" class="group relative rounded-lg overflow-hidden aspect-video block">
          <img
            src={photo.url}
            alt={`Foto ${i + 1} — ${photo.label}`}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-center justify-center">
            <span class="text-white text-xs opacity-0 group-hover:opacity-100 transition-opacity font-medium">
              Ver original ↗
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
