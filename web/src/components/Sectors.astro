---
const sectors = [
  'Empresas mineras',
  'Empresas contratistas de la minería',
  'Plantas industriales',
  'Áreas de mantención',
  'Áreas de operaciones',
  'Equipos de ingeniería',
  'Pymes proveedoras de servicios técnicos',
  'Instituciones que requieren capacitación técnica',
]
---

<section class="py-24 bg-[#0D0D0D] text-white" aria-labelledby="sectores-heading">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-start">

      <!-- Encabezado a la izquierda -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-6 h-0.5 bg-[#C4610A]" aria-hidden="true"></span>
          <span class="text-[#C4610A] text-xs font-semibold uppercase tracking-[0.2em]">¿A quién atendemos?</span>
        </div>
        <h2 id="sectores-heading" class="text-4xl md:text-5xl font-bold leading-tight mb-6" style="font-family:'Barlow Condensed',sans-serif">
          Sectores que<br/>servimos
        </h2>
        <p class="text-gray-400 leading-relaxed mb-8">
          Nuestra experiencia abarca múltiples actores de la cadena minera e industrial,
          desde operadores hasta instituciones de capacitación técnica.
        </p>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 bg-[#C4610A] hover:bg-[#E07B2A] text-white font-semibold px-6 py-3 rounded transition-colors text-sm min-h-[48px]"
        >
          Hablar con un especialista
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Lista a la derecha -->
      <ul class="space-y-3" role="list">
        {sectors.map((sector, i) => (
          <li class="flex items-center gap-4 border border-white/10 rounded-lg px-5 py-4 hover:border-[#C4610A]/50 hover:bg-white/5 transition-all duration-200 group">
            <!-- Número -->
            <span class="text-[#C4610A] font-bold text-sm font-mono w-6 shrink-0" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-gray-300 group-hover:text-white text-sm transition-colors">{sector}</span>
          </li>
        ))}
      </ul>

    </div>
  </div>
</section>
