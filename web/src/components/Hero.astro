---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- LCP image: fetchpriority="high", loading="eager", width/height explícitos (core-web-vitals CLS) -->
  <div class="absolute inset-0">
    <!-- TODO: reemplazar src con imagen real del cliente (faena minera) -->
    <img
      src="https://picsum.photos/seed/mining-hero/1920/1080"
      alt=""
      role="presentation"
      class="w-full h-full object-cover"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      width="1920"
      height="1080"
    />
    <!-- Overlay en degradado, más profundo abajo para legibilidad -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0D0D0D]/75 via-[#0D0D0D]/60 to-[#0D0D0D]/85" aria-hidden="true"></div>
    <!-- Franja naranja sutil en la parte inferior -->
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#C4610A]" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-20 text-white">
    <!-- Eyebrow con marca naranja — elemento firma del diseño -->
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-0.5 bg-[#C4610A]" aria-hidden="true"></span>
      <span class="text-[#C4610A] text-xs font-semibold uppercase tracking-[0.2em]">Asesoría técnica minera · Chile</span>
    </div>

    <!-- H1 con Barlow Condensed en tamaño máximo — riesgo estético deliberado -->
    <h1 class="text-6xl md:text-8xl lg:text-9xl font-extrabold uppercase leading-none tracking-tight mb-6" style="font-family:'Barlow Condensed',sans-serif">
      Ingeniería<br/>
      <span class="text-[#C4610A]">Millar</span>
    </h1>

    <p class="text-lg md:text-xl text-gray-200 max-w-xl mb-4 leading-relaxed">
      Asesoría técnica, ingeniería y soluciones para la industria minera
    </p>
    <p class="text-sm md:text-base text-gray-400 max-w-2xl mb-10 leading-relaxed">
      Más de 20 años de experiencia apoyando operaciones, proyectos y equipos
      de trabajo en la industria minera e ingeniería del país.
    </p>

    <!-- CTAs — primary + secondary (ui-ux-pro-max: un solo CTA primario) -->
    <div class="flex flex-wrap gap-4">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-[#C4610A] hover:bg-[#E07B2A] text-white font-semibold px-8 py-4 rounded transition-colors text-base min-h-[48px]"
      >
        Contáctanos
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#servicios"
        class="inline-flex items-center gap-2 border border-white/30 hover:border-white text-white font-semibold px-8 py-4 rounded transition-colors text-base min-h-[48px]"
      >
        Ver servicios
      </a>
    </div>

    <!-- Stats rápidas -->
    <div class="flex flex-wrap gap-8 mt-16 pt-8 border-t border-white/10">
      {[
        { value: '+20', label: 'años de experiencia' },
        { value: '4', label: 'regiones de cobertura' },
        { value: '6', label: 'áreas de servicio' },
      ].map(s => (
        <div>
          <div class="text-3xl font-bold text-[#C4610A]" style="font-family:'Barlow Condensed',sans-serif">{s.value}</div>
          <div class="text-xs text-gray-400 uppercase tracking-wider mt-1">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30 animate-bounce" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
