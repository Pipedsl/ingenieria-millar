---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center">
  <!-- Background image — fotos destacadas del cliente (⭐) -->
  <div class="absolute inset-0 bg-[#111111]">
    <img
      src="https://bancoaudiovisual.marcachile.cl/images/b5fbe40d-d64c-483f-ae42-0cd8e54b7f66"
      alt="Faena minera"
      class="w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center text-white pt-16">
    <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-4">
      Ingeniería <span class="text-[#C4610A]">Millar</span>
    </h1>
    <p class="text-xl md:text-2xl text-gray-200 mb-6">
      Asesoría técnica, ingeniería y soluciones para la industria minera
    </p>
    <p class="text-base md:text-lg text-gray-300 max-w-2xl mx-auto mb-10">
      Más de 20 años de experiencia apoyando operaciones, proyectos y equipos
      de trabajo en la industria minera e ingeniería del país.
    </p>
    <a
      href="#contacto"
      class="inline-block bg-[#C4610A] hover:bg-[#E07B2A] text-white font-semibold px-8 py-4 rounded transition-colors text-lg"
    >
      Contáctanos
    </a>
  </div>
</section>
