---
const cities = [
  {
    name: 'Antofagasta',
    region: 'Región de Antofagasta',
    image: 'https://bancoaudiovisual.marcachile.cl/images/9673ed6f-d72b-44ec-8d61-43a622f3de3a',
  },
  {
    name: 'Calama',
    region: 'Región de Antofagasta',
    image: 'https://bancoaudiovisual.marcachile.cl/images/be09f1df-bb01-4611-8525-12e0f938af22',
  },
  {
    name: 'Santiago',
    region: 'Región Metropolitana',
    image: 'https://bancoaudiovisual.marcachile.cl/images/b8b7dc44-d97b-4444-9df4-d82acaeccd55',
  },
  {
    name: 'Concepción',
    region: 'Región del Biobío',
    image: 'https://bancoaudiovisual.marcachile.cl/images/c60dd987-5505-4a13-94dc-1286e3bb3d8f',
  },
]
---

<section class="py-24 bg-white" aria-labelledby="cobertura-heading">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="w-6 h-0.5 bg-[#C4610A]" aria-hidden="true"></span>
        <span class="text-[#C4610A] text-xs font-semibold uppercase tracking-[0.2em]">Dónde estamos</span>
        <span class="w-6 h-0.5 bg-[#C4610A]" aria-hidden="true"></span>
      </div>
      <h2 id="cobertura-heading" class="text-4xl md:text-5xl font-bold text-[#0D0D0D] mb-4" style="font-family:'Barlow Condensed',sans-serif">
        Cobertura nacional
      </h2>
      <p class="text-gray-500 max-w-xl mx-auto">
        Presencia en zonas estratégicas para la industria minera e industrial de Chile.
      </p>
    </div>

    <!-- TODO: evaluar mapa SVG de Chile con pines interactivos -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {cities.map(city => (
        <div class="relative rounded-xl overflow-hidden aspect-[3/4] group">
          <img
            src={city.image}
            alt={`Vista de ${city.name}, ${city.region}`}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            decoding="async"
            width="400"
            height="533"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0D]/90 via-[#0D0D0D]/30 to-transparent"></div>
          <!-- Franja naranja -->
          <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#C4610A] scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left" aria-hidden="true"></div>
          <!-- Texto -->
          <div class="absolute bottom-0 inset-x-0 p-5 text-white">
            <div class="flex items-center gap-2 mb-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-[#C4610A]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
              </svg>
              <span class="font-bold text-lg leading-none" style="font-family:'Barlow Condensed',sans-serif">{city.name}</span>
            </div>
            <div class="text-xs text-white/60">{city.region}</div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
