---
const links = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Contacto', href: '#contacto' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#0D0D0D]/96 backdrop-blur-sm border-b border-white/5">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between" aria-label="Navegación principal">
    <a href="#inicio" class="flex items-center gap-2 group">
      <!-- Marca vertical en naranja -->
      <span class="w-0.5 h-6 bg-[#C4610A]" aria-hidden="true"></span>
      <span class="font-display text-white font-bold text-lg tracking-wide uppercase" style="font-family:'Barlow Condensed',sans-serif">
        Ingeniería <span class="text-[#C4610A]">Millar</span>
      </span>
    </a>

    <!-- Desktop -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="text-gray-400 hover:text-white text-sm font-medium transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:w-0 after:h-px after:bg-[#C4610A] after:transition-all hover:after:w-full"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="#contacto"
      class="hidden md:inline-flex items-center gap-2 bg-[#C4610A] hover:bg-[#E07B2A] text-white text-sm font-semibold px-5 py-2 rounded transition-colors duration-200"
    >
      Contáctanos
    </a>

    <!-- Mobile hamburger — accesibilidad: aria-label (accessibility skill) -->
    <button
      class="md:hidden text-white p-2 min-w-[44px] min-h-[44px] flex items-center justify-center"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      id="mobile-menu-btn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-[#0D0D0D] border-t border-white/10" role="dialog" aria-label="Menú móvil">
    <ul class="max-w-6xl mx-auto px-6 py-4 space-y-1" role="list">
      {links.map(link => (
        <li>
          <a href={link.href} class="block py-3 text-gray-300 hover:text-white font-medium transition-colors border-b border-white/5">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="#contacto" class="block w-full text-center bg-[#C4610A] hover:bg-[#E07B2A] text-white font-semibold px-5 py-3 rounded transition-colors">
          Contáctanos
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false
    btn.setAttribute('aria-expanded', String(open))
  })
  // Cierra al hacer click en un link
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden')
      btn?.setAttribute('aria-expanded', 'false')
    })
  })
</script>
