---
const year = new Date().getFullYear()
---

<footer class="bg-[#111111] text-gray-400 py-10">
  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
    <div>
      <span class="text-white font-semibold">Ingeniería Millar</span> © {year}
    </div>

    <div class="text-center text-gray-500">
      Antofagasta · Calama · Santiago · Concepción
    </div>

    <!-- TODO: agregar URLs reales de redes sociales cuando el cliente las entregue -->
    <div class="flex items-center gap-6">
      <div class="flex gap-4">
        <a href="#" class="hover:text-[#C4610A] transition-colors">LinkedIn</a>
        <a href="#" class="hover:text-[#C4610A] transition-colors">Instagram</a>
      </div>
      <a
        href="https://webiados.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 text-gray-500 hover:text-white transition-colors"
      >
        Un producto de <span class="text-white font-semibold ml-1">Webiados</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-0.5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
          <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
